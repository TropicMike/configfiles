alias m=less

# `e` is the interactive editor shortcut: emacs if installed, else nano.
# EDITOR is set to match for tools like git.
if command -v emacs &>/dev/null
then
  export EDITOR=emacs
  alias e=emacs
else
  export EDITOR=nano
  alias e=nano
fi

alias z=clear
alias md=mkdir

if [[ "$(uname)" == "Darwin" ]]; then
  alias ls='ls -G'
  # CLICOLOR_FORCE keeps ls colors when piping into less (BSD ls drops them otherwise)
  alias lsd='CLICOLOR_FORCE=1 ls -G -lath|less -R'
else
  alias ls='ls --color'
  alias lsd='ls --color=always -lath|less -R'
fi

function rmbak() { find . -maxdepth 1 -name '*~' -delete; find . -maxdepth 1 -name '#*#' -delete; }

alias hex='hexdump -C'

# Always run rsync with -a (archive), -S (sparse), and -P (progress + partial)
alias rsync='rsync -aSP'

# less options: -X leave output on screen after quitting, -i case-insensitive search
export LESS=-Xi

if [[ "$(uname)" == "Linux" ]]; then
  alias open='xdg-open'
fi

alias bc='bc -l'
command -v bmon >/dev/null 2>&1 && alias ntop='bmon'

# Print each interface and its IPv4 address; use `ip` if available, else fall back to ifconfig.
function ipa() {
  if command -v ip &> /dev/null; then
    ip -4 -o addr show | awk '{print $2, $4}' | sed 's/\/.*//'
  else
    ifconfig | grep -E "^[a-z]|inet " | awk '/^[a-z]/ {iface=$1} /inet / {print iface, $2}'
  fi
}

# On every new shell, check in the background whether the configfiles repo has
# new upstream commits and print a reminder to pull + deploy. The
# ( { ... } & ) form detaches the work so shell startup isn't delayed and no
# job-control notice is printed. No-op on machines without the repo cloned.
# Note: this fetches from the remote on each shell, and the reminder reprints
# every shell until you pull.
_cfg_repo=~/Repos/configfiles
# On Windows (Git Bash), the clone lives at C:\Repos\configfiles instead.
[ -d "$_cfg_repo/.git" ] || _cfg_repo=/c/Repos/configfiles
if [ -d "$_cfg_repo/.git" ]; then
  ( {
      if git -C "$_cfg_repo" fetch -q 2>/dev/null; then
        # Resolve the remote's default branch (origin/HEAD, set at clone time)
        # rather than hardcoding master, so a rename to main keeps working.
        _def="$(git -C "$_cfg_repo" rev-parse --abbrev-ref origin/HEAD 2>/dev/null)"
        _n="$(git -C "$_cfg_repo" rev-list --count "HEAD..${_def:-origin/master}" 2>/dev/null)"
        [ "${_n:-0}" -gt 0 ] &&
          echo "configfiles: ${_n} new commit(s) upstream — run: git -C $_cfg_repo pull && $_cfg_repo/deploy.sh"
      fi
    } & )
fi
unset _cfg_repo
